{
  "name": "zenith-life-os",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy-first Life OS â€” free forever",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter @zenith/web dev",
    "build": "pnpm --filter @zenith/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:rls": "pnpm --filter @zenith/db test:rls",
    "check:mvp": "tsx scripts/check-mvp-scope.ts",
    "check:naming": "tsx scripts/check-naming.ts",
    "check:rls": "tsx scripts/check-rls.ts",
    "check:migrations": "tsx scripts/check-migrations.ts",
    "check:crypto": "tsx scripts/check-encryption-primitives.ts",
    "check:tenants": "tsx scripts/check-tenant-boundaries.ts",
    "check:money": "tsx scripts/check-money-columns.ts",
    "check:vault-leak": "tsx scripts/check-no-vault-leak.ts",
    "check:audit-events": "tsx scripts/check-audit-events.ts",
    "check:routes-envelope": "tsx scripts/check-routes-envelope.ts",
    "check:idempotency": "tsx scripts/check-idempotency.ts",
    "check:no-sql-in-routes": "tsx scripts/check-no-sql-in-routes.ts",
    "check:no-ai-in-render": "tsx scripts/check-no-ai-in-render.ts",
    "check:timezone-hardcode": "tsx scripts/check-timezone-hardcode.ts",
    "check:worker-leases": "tsx scripts/check-worker-leases.ts",
    "check:dark-only-tokens": "tsx scripts/check-dark-only-tokens.ts",
    "check:sw-audit": "tsx scripts/check-sw-audit.ts",
    "check:vapid-key-not-in-client": "tsx scripts/check-vapid-key-not-in-client.ts",
    "check:all": "pnpm check:naming && pnpm check:rls && pnpm check:migrations && pnpm check:crypto && pnpm check:tenants && pnpm check:money && pnpm check:vault-leak && pnpm check:audit-events && pnpm check:routes-envelope && pnpm check:idempotency && pnpm check:no-sql-in-routes && pnpm check:no-ai-in-render && pnpm check:timezone-hardcode && pnpm check:worker-leases && pnpm check:dark-only-tokens && pnpm check:sw-audit && pnpm check:vapid-key-not-in-client && pnpm check:audit-merkle",
    "gen:error-docs": "tsx scripts/gen-error-docs.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:gen-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/shared/src/types/database.ts",
    "check:audit-merkle": "tsx scripts/verify-audit-chain.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3"
  }
}